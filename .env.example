# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and adjust. docker-compose reads this file automatically.
# Every value has a built-in default (see config.go); set here only to override.
# ─────────────────────────────────────────────────────────────────────────────

# MODE selects the process role for a direct `go run .`: server | worker | all (default).
# Under docker-compose the api + worker containers each set MODE for you.
# MODE=all

# LLM — one generic config for every provider (adding a provider needs no new keys).
#   LLM_PROVIDER : openai | ollama | mock.  Empty = auto (openai if LLM_API_KEY set, else mock).
#   LLM_MODEL    : e.g. gpt-4o-mini | llama3.2 | gemma4:latest   (blank = provider default)
#   LLM_API_KEY  : required for openai/groq; unused for ollama/mock
#   LLM_BASE_URL : endpoint; blank = provider default. Examples:
#                    OpenAI : https://api.openai.com/v1
#                    Groq   : https://api.groq.com/openai/v1
#                    Ollama : http://localhost:11434   (in Docker: http://host.docker.internal:11434)
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# Classification confidence floor; below this a result is downgraded to UNCLASSIFIED
CONFIDENCE_THRESHOLD=0.6

# Worker pool / retry policy
WORKER_CONCURRENCY=4
MAX_ATTEMPTS=5
LEASE_TIMEOUT=30s
BASE_BACKOFF=2s
MAX_BACKOFF=5m
POLL_INTERVAL=1s

# Server / logging
PORT=8080
LOG_LEVEL=info

# DATABASE_URL is set by docker-compose (over the service network). Only needed for a
# direct `go run .` against the published port:
# DATABASE_URL=postgres://postgres:postgres@localhost:5643/webhooks?sslmode=disable
